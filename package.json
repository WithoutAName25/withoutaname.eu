    "eslint-plugin-svelte": "^3.15.2",
    "globals": "^17.4.0",
    "open-props": "^1.7.23",
    "postcss": "^8.5.8",
    "postcss-jit-props": "^1.0.16",
    "postcss-preset-env": "^11.2.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "sass": "^1.98.0",
    "svelte": "5.53.12",
    "svelte-check": "^4.4.5",
    "svelte-preprocess": "^6.0.3",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
